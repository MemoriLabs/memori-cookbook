# Copy this file to .env and fill in your values

# LLM Provider — choose one: openai, gemini, claude (default: openai)
LLM_PROVIDER=openai

# API key for your chosen provider (set the one that matches LLM_PROVIDER)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional model overrides
WELLNESS_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash-exp
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional
SQLITE_DB_PATH=./memori.sqlite
WELLNESS_SQLITE_PATH=./wellness.sqlite
