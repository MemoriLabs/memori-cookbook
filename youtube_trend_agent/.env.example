# Copy this file to .env and fill in your values

# LLM Provider — choose one: openai, gemini, claude (default: openai)
# Set the API key that matches your chosen provider.
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

EXA_API_KEY=your-exa-api-key

# Optional model overrides
YOUTUBE_TREND_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash-exp
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional
MEMORI_API_KEY=your-memori-api-key
SQLITE_DB_PATH=./memori.sqlite
